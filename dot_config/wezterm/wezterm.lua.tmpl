-- Helper functions
-- Helper to merge two tables, like nix's // operator
local function merge(a, b)
  local result = {}

  -- copy all keys from a first
  for k, v in pairs(a) do
    result[k] = v
  end

  -- update/override from b
  for k, v2 in pairs(b) do
    local v1 = result[k]
    if type(v1) == "table" and type(v2) == "table" then
      result[k] = merge(v1, v2)
    else
      result[k] = v2
    end
  end

  return result
end

