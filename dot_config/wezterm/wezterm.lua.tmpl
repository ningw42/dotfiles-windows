-- Tab Title: show CWD instead of the process exe path
local function basename(s)
  return string.gsub(s, '(.*[/\\])(.*)', '%2')
end

-- Strip leading / from file_path on Windows (e.g. /C:/Users/... -> C:/Users/...)
local function strip_file_path(p)
  if p and p:match('^/[A-Za-z]:') then
    return p:sub(2)
  end
  return p
end

local home = strip_file_path(
  (os.getenv('USERPROFILE') or os.getenv('HOME') or ''):gsub('\\', '/')
)

wezterm.on('format-tab-title', function(tab, tabs, panes, cfg, hover, max_width)
  -- Explicit title takes priority
  if tab.tab_title and #tab.tab_title > 0 then
    return tab.tab_title
  end

  local title = nil

  local pane = tab.active_pane
  local proc = basename(pane.foreground_process_name or '')

  -- For SSH sessions, let the remote shell's title (OSC 2) pass through.
  -- pane.title may be stale (still holding the local shell's CWD title from
  -- before ssh launched), so ignore it if it looks like a local Windows path.
  if proc == 'ssh.exe' or proc == 'ssh' then
    local t = pane.title or ''
    if t == '' or t:match('^~\\') or t == '~' or t:match('^[A-Za-z]:\\') then
      t = 'ssh'
    end
    return t
  end

  -- For shell processes, prefer OSC 2 title (set by Invoke-Starship-PreCommand)
  local shells = { ['pwsh.exe']=1, ['pwsh']=1, ['powershell.exe']=1,
                   ['bash']=1, ['zsh']=1, ['fish']=1, ['nu']=1, ['cmd.exe']=1 }
  if shells[proc] and pane.title and #pane.title > 0
     and not pane.title:find('[/\\][%w%s%.%-_]+%.[eE][xX][eE]') then
    title = pane.title
  end

  -- For non-shell processes or missing OSC 2, build title from CWD (OSC 7)
  if not title then
    -- If the app set its own title via OSC 2, prefer that
    if pane.title and #pane.title > 0
       and not pane.title:find('[/\\][%w%s%.%-_]+%.[eE][xX][eE]') then
      title = pane.title
    else
      local cwd = pane.current_working_dir
      if cwd then
        local path = strip_file_path((cwd.file_path or ''):gsub('\\', '/'))
        if path and #path > 1 and path:sub(-1) == '/' then path = path:sub(1, -2) end
        if path and path == home then
          path = '~'
        elseif path and path:sub(1, #home + 1) == home .. '/' then
          path = '~/' .. path:sub(#home + 2)
        end
        if path then
          path = path:gsub('/', '\\')
        end
        if path and #path > 0 then
          if not shells[proc] and proc ~= '' then
            title = proc .. ': ' .. path
          else
            title = path
          end
        end
      end
    end
  end

  -- Fall back to pane title (OSC 2) or process basename
  if not title or title == '' then
    title = pane.title
    if not title or title == '' or title:find('[/\\]') then
      title = basename(pane.foreground_process_name or '')
      if title == '' then title = 'Terminal' end
    end
  end

  -- Pad short titles so tabs don't get too narrow
  local min_width = 10
  local padding = min_width - #title
  if padding > 0 then
    local left = math.floor(padding / 2)
    title = string.rep(' ', left) .. title .. string.rep(' ', padding - left)
  end

  return title
end)

