            ],
            "output": [
              "text"
            ]
          },
          "name": "GPT-5.5",
          "options": {
            "reasoningEffort": "xhigh"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "none": {
              "reasoningEffort": "none"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      },
      "name": "LiteLLM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}",
        "baseURL": "https://litellm.ningw.net/v1"
      }
    }
  }
}
