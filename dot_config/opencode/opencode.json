{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "copilot-proxy",
    "litellm"
  ],
  "mcp": {
    "brave-search": {
      "enabled": true,
      "type": "remote",
      "url": "https://brave-search-mcp.ningw.net/mcp"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  },
  "provider": {
    "copilot-proxy": {
      "models": {
        "claude-haiku-4.5": {
          "cost": {
            "cache_read": 0.1,
            "cache_write": 1.25,
            "input": 1,
            "output": 5
          },
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Haiku 4.5"
        },
        "claude-opus-4.8": {
          "cost": {
            "cache_read": 0.5,
            "cache_write": 6.25,
            "input": 5,
            "output": 25
          },
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Opus 4.8",
          "options": {
            "effort": "xhigh",
            "thinking": {
              "display": "summarized",
              "type": "adaptive"
            }
          },
          "variants": {
            "high": {
              "effort": "high",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "low": {
              "effort": "low",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "max": {
              "effort": "max",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "medium": {
              "effort": "medium",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "xhigh": {
              "effort": "xhigh",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            }
          }
        },
        "claude-sonnet-5": {
          "cost": {
            "cache_read": 0.3,
            "cache_write": 3.75,
            "input": 3,
            "output": 15
          },
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Sonnet 5",
          "options": {
            "effort": "xhigh",
            "thinking": {
              "display": "summarized",
              "type": "adaptive"
            }
          },
          "variants": {
            "high": {
              "effort": "high",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "low": {
              "effort": "low",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "max": {
              "effort": "max",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "medium": {
              "effort": "medium",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            },
            "xhigh": {
              "effort": "xhigh",
              "thinking": {
                "display": "summarized",
                "type": "adaptive"
              }
            }
          }
        }
      },
      "name": "Copilot Proxy",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}",
        "baseURL": "https://copilot.ningw.net/v1"
      }
    },
    "litellm": {
      "models": {
        "gpt-5.4": {
          "cost": {
            "cache_read": 0.25,
            "input": 2.5,
            "output": 15
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "GPT-5.4",
          "options": {
            "reasoningEffort": "xhigh"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "none": {
              "reasoningEffort": "none"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "gpt-5.5": {
          "cost": {
            "cache_read": 0.5,
            "input": 5,
            "output": 30
          },
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
