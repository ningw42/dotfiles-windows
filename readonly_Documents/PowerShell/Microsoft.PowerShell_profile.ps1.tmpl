#region Environment Variables

# yazi: file(1) executable
# see https://yazi-rs.github.io/docs/installation#windows
$Env:YAZI_FILE_ONE = "$Env:USERPROFILE\scoop\apps\git\current\usr\bin\file.exe"

# eza: the number of spaces to print between icon and filename
$Env:EZA_ICON_SPACING = 2

# default editor
$Env:EDITOR = "nvim"

# bat config directory
$Env:BAT_CONFIG_DIR = "$Env:USERPROFILE\.config\bat"

# PAGER
$Env:PAGER = "moor"
$Env:MOOR = "--no-linenumbers --statusbar=bold --tab-size=2 --style=catppuccin-mocha"

# lazygit config
$Env:LG_CONFIG_FILE = "$Env:LOCALAPPDATA\lazygit\config.yml,$Env:LOCALAPPDATA\lazygit\{{ .colorscheme }}-blue.yml";

# claude: prefer Router-Maestro over LiteLLM
{{ if eq .password_manager "bitwarden" -}}
$Env:ANTHROPIC_AUTH_TOKEN = "{{ (bitwarden "item" "RouterMaestroAPIKey").login.password }}"
{{ else if eq .password_manager "1password" -}}
$Env:ANTHROPIC_AUTH_TOKEN = "{{ onepasswordRead "op://Private/RouterMaestroAPIKey/credential" }}"
{{ end }}
# codex: prefer LiteLLM over Router-Maestro
{{ if eq .password_manager "bitwarden" -}}
$Env:CODEX_API_KEY = "{{ (bitwarden "item" "LiteLLMMasterKey").login.password }}"
{{ else if eq .password_manager "1password" -}}
$Env:CODEX_API_KEY = "{{ onepasswordRead "op://Private/LiteLLMMasterKey/credential" }}"
{{ end -}}
#endregion Environment Variables


#region Functions

# alias for chezmoi
function cz
{
  chezmoi $args
}

# alias for entering local chezmoi repository
function czcd
{
  Set-Location $(chezmoi source-path)
}

# alias for launching yazi
function y
{
    $tmp = [System.IO.Path]::GetTempFileName()
    yazi $args --cwd-file="$tmp"
    $cwd = Get-Content -Path $tmp
    if (-not [String]::IsNullOrEmpty($cwd) -and $cwd -ne $PWD.Path) {
        Set-Location -LiteralPath $cwd
    }
    Remove-Item -Path $tmp
}

Function l
{
  eza --icons --no-quotes --group-directories-first --no-symlinks $args
}

Function ll
{
  eza --header --icons --long --octal-permissions --binary --group --time-style='+%F %T' --color-scale=age --no-quotes --group-directories-first --all $args
}

Function lt
{
  eza --header --icons --long --octal-permissions --binary --group --time-style='+%F %T' --color-scale=age --no-quotes --group-directories-first --all --tree $args
}

Function lg
{
  lazygit @args
}

Function cc
{
  claude --model "opus[1m]" @args
}

#endregion Functions


#region Terminal Title
# Starship calls this before each prompt render.
# Emit OSC 7 (CWD) and OSC 2 (tab title) so terminals like WezTerm know where we are.
function Invoke-Starship-PreCommand {
    $loc = $executionContext.SessionState.Path.CurrentLocation
    if ($loc.Provider.Name -eq "FileSystem") {
        $esc = [char]27
        $providerPath = $loc.ProviderPath -replace "\\", "/"
        # OSC 7: current working directory
        $osc7 = "${esc}]7;file://${env:COMPUTERNAME}/${providerPath}${esc}\"
        # OSC 2: tab title
        # Use starship's directory module for fish-style truncated paths
        $title = (starship module directory 2>$null) -replace "`e\[[0-9;]*m", ""
        $title = $title.Trim()
        if (-not $title) { $title = $loc.ProviderPath }
        $osc2 = "${esc}]2;${title}${esc}\"
        $host.ui.Write("${osc7}${osc2}")
    }
}
#endregion Terminal Title


# This is recommended to be the last expression in $PROFILE
Invoke-Expression (&starship init powershell)

# But zoxide doesn't work if it is before starship, see https://github.com/ajeetdsouza/zoxide/issues/74
Invoke-Expression (& { (zoxide init powershell | Out-String) })
