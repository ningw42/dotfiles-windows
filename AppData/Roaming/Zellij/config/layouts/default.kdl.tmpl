{{/*
  Zellij default layout — Windows/chezmoi port of nixfiles
  modules/home-manager/zellij/layouts/default.kdl.jinja.

  A single zjstatus bar (top, borderless) replaces zellij's built-in
  tab-bar/status-bar. zjstatus.wasm is a LOCAL copy fetched by chezmoi as a
  checksummed external (see ../plugins/.chezmoiexternal.toml) and referenced via
  file: below — no network at launch. On first launch and after any version bump,
  zellij prompts to grant zjstatus permissions: focus the bar pane and press `y`.

  Bar colours: per-scheme palette below, mirroring the nixfiles barColors mapping
  (catppuccin: bg0=mantle bg1=surface0 bg2=surface2 fg=text; orange=peach,
  magenta=mauve. gruvbox-dark @ dark/medium: bg0=bg0_h bg1=bg1 bg2=bg3 fg=fg;
  magenta=purple; neutral accents). Hexes are exact values from nixfiles
  lib/catppuccin.nix & lib/gruvbox.nix.

  ⚠️ Colorscheme-conditional: this dict is one of the per-tool theme blocks the
  AGENTS.md "sync gotcha" tracks. Adding/renaming a scheme means adding an entry
  here too.
*/ -}}
{{- $palettes := dict
  "catppuccin-latte"     (dict "bg0" "#e6e9ef" "bg1" "#ccd0da" "bg2" "#acb0be" "fg" "#4c4f69" "red" "#d20f39" "green" "#40a02b" "yellow" "#df8e1d" "orange" "#fe640b" "magenta" "#8839ef" "blue" "#1e66f5")
  "catppuccin-frappe"    (dict "bg0" "#292c3c" "bg1" "#414559" "bg2" "#626880" "fg" "#c6d0f5" "red" "#e78284" "green" "#a6d189" "yellow" "#e5c890" "orange" "#ef9f76" "magenta" "#ca9ee6" "blue" "#8caaee")
  "catppuccin-macchiato" (dict "bg0" "#1e2030" "bg1" "#363a4f" "bg2" "#5b6078" "fg" "#cad3f5" "red" "#ed8796" "green" "#a6da95" "yellow" "#eed49f" "orange" "#f5a97f" "magenta" "#c6a0f6" "blue" "#8aadf4")
  "catppuccin-mocha"     (dict "bg0" "#181825" "bg1" "#313244" "bg2" "#585b70" "fg" "#cdd6f4" "red" "#f38ba8" "green" "#a6e3a1" "yellow" "#f9e2af" "orange" "#fab387" "magenta" "#cba6f7" "blue" "#89b4fa")
  "gruvbox-dark"         (dict "bg0" "#1d2021" "bg1" "#3c3836" "bg2" "#665c54" "fg" "#ebdbb2" "red" "#cc241d" "green" "#98971a" "yellow" "#d79921" "orange" "#d65d0e" "magenta" "#b16286" "blue" "#458588")
-}}
{{- $c := index $palettes .colorscheme -}}
{{- if not $c }}{{ fail (printf "zellij layout: no zjstatus palette for colorscheme %q — add it to $palettes" .colorscheme) }}{{ end -}}
layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="file:~/AppData/Roaming/Zellij/config/plugins/zjstatus.wasm" {
        format_left   "#[bg={{ $c.bg1 }},fg={{ $c.fg }},bold] {session} #[bg={{ $c.bg1 }}]"
        format_center "{tabs}"
        format_right  "{mode}#[bg={{ $c.bg1 }},fg={{ $c.fg }},bold] {{ env "USERNAME" }}@{{ .chezmoi.hostname }} "
        format_space  "#[bg={{ $c.bg0 }}]"

        tab_normal "#[bg={{ $c.bg0 }},fg={{ $c.bg2 }}] {name} "
        tab_active "#[bg={{ $c.bg1 }},fg={{ $c.fg }},bold] {name} "
        tab_sync_indicator       " "
        tab_fullscreen_indicator " 󰊓"
        tab_floating_indicator   " 󰹙"

        mode_normal       "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   NORMAL "
        mode_locked       "#[bg={{ $c.bg1 }},fg={{ $c.red }},bold]   LOCKED   "
        mode_pane         "#[bg={{ $c.bg1 }},fg={{ $c.yellow }},bold]   PANE "
        mode_tab          "#[bg={{ $c.bg1 }},fg={{ $c.yellow }},bold]   TAB "
        mode_resize       "#[bg={{ $c.bg1 }},fg={{ $c.magenta }},bold]   RESIZE "
        mode_scroll       "#[bg={{ $c.bg1 }},fg={{ $c.blue }},bold]   SCROLL "
        mode_enter_search "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   ENTER-SEARCH "
        mode_search       "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   SEARCH "
        mode_rename_tab   "#[bg={{ $c.bg1 }},fg={{ $c.orange }},bold]   RENAME-TAB "
        mode_rename_pane  "#[bg={{ $c.bg1 }},fg={{ $c.orange }},bold]   RENAME-PANE "
        mode_session      "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   SESSION "
        mode_move         "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   MOVE "
        mode_prompt       "#[bg={{ $c.bg1 }},fg={{ $c.green }},bold]   PROMPT "
        mode_tmux         "#[bg={{ $c.bg1 }},fg={{ $c.magenta }},bold]   TMUX "
      }
    }
    children
  }
}
