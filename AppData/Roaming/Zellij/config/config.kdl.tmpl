// Zellij configuration — Windows / chezmoi.
//
// Mirrors the nixfiles home-manager zellij module (programs.zellij.settings) as
// closely as Windows allows. Deliberately minimal: keybindings are NOT defined
// here (we rely on zellij's built-in defaults, as nixfiles does) and themes are
// NOT defined inline (we reference zellij's built-in theme names — see `theme`).
// The custom zjstatus status bar lives in layouts/default.kdl (the default
// layout zellij auto-loads on startup).

// On Windows we pin PowerShell 7 (pwsh.exe), NOT Windows PowerShell 5.x
// (powershell.exe). Resolved from PATH (WinGet Microsoft.PowerShell installs it
// to "C:\Program Files\PowerShell\7"). The one intentional deviation from
// nixfiles, which uses the platform default shell.
default_shell "pwsh.exe"

// nixfiles parity: the zjstatus bar draws its own styling, so drop pane frames.
pane_frames false

// nixfiles parity: zellij >=0.44 auto-formats detected URLs as OSC8 hyperlinks
// (dotted underline). A raw terminal/SSH session leaves them plain, so turn the
// auto-formatting off to match. Distinct from `styled_underlines` (left at its
// default true) so editor undercurl/diagnostics still render.
osc8_hyperlinks false

// Pane theme: wired to chezmoi's `colorscheme` data var. All five supported
// schemes (catppuccin-latte/frappe/macchiato/mocha, gruvbox-dark) are exact names
// of zellij BUILT-IN themes, so this passes through unchanged — no inline theme
// definitions, no name remapping. The built-in catppuccin themes use zellij's
// component-based theme spec (distinct text_selected background = Surface2), which
// fixes the invisible-selection issue (#2747) the old inline workaround addressed.
theme {{ .colorscheme | quote }}
