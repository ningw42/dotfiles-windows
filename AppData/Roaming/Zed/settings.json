// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4o",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "github-copilot": {
      "type": "registry"
    }
  },
  "agent_buffer_font_size": 16.0,
  "buffer_line_height": "standard",
  "base_keymap": "VSCode",
  "icon_theme": "Catppuccin Frappé",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "buffer_font_family": "Berkeley Mono Retina",
  "buffer_font_fallbacks": ["Sarasa Fixed SC"],
  "buffer_font_size": 16.0,
  "buffer_font_features": {
    "ss02": true,
  },
  "ui_font_family": "Berkeley Mono Retina",
  "ui_font_fallbacks": ["Sarasa Fixed SC"],
  "ui_font_size": 18.0,
  "ui_font_features": {
    "ss02": true,
  },
  "terminal": {
    "font_family": "Berkeley Mono Retina",
    "font_fallbacks": ["Symbols Nerd Font Berkeley Mono", "Sarasa Fixed SC"],
    "font_size": 16.0,
    "font_features": {
      "ss02": true,
    },
    "line_height": { "custom": 1.1 },
  },
  "theme": "Catppuccin Mocha",
}
