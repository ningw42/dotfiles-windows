{{ if eq .chezmoi.os "windows" -}}
# Regenerate rtk's awareness files for Codex and Copilot. Re-runs only when the
# rtk binary version changes, since rtk owns the canonical content (rtk init
# writes them).
#
# Claude Code is intentionally NOT initialized here: its PreToolUse hook
# (`rtk hook claude`, wired in dot_claude/settings.json.tmpl) transparently
# rewrites every Bash call via `updatedInput`, so the RTK.md / CLAUDE.md prompt
# injection is redundant. Mirrors nixfiles' hook-only claude-code module; the
# orphaned ~/.claude/{RTK,CLAUDE}.md are purged via .chezmoiremove. The only
# thing RTK.md would add is awareness of meta-commands (rtk gain/discover) — not
# worth the per-session prompt tokens given the rewrite is deterministic.
#
# rtk version: {{ output "rtk" "--version" | trim }}

# Codex: writes ~/.codex/RTK.md and adds @RTK.md to ~/.codex/AGENTS.md. Codex
# has no command-rewrite hook, so this instruction file is its only integration.
& rtk init -g --codex | Out-Null

# Copilot CLI: hook-only, same rationale as Claude. The Copilot path is
# "deny-with-suggestion" (rtk's `rtk hook copilot` blocks the bare command and
# suggests the rtk-prefixed form, which the agent retries) — deterministic and
# hook-driven, so the bundled copilot-instructions.md prompt is redundant.
# `rtk init --copilot` writes BOTH the hook (~/.copilot/hooks/rtk-rewrite.json)
# and the instructions, and on Windows rtk ignores a redirected HOME/USERPROFILE
# (writes straight to the real ~/.copilot), so we can't sandbox-and-copy like
# nixfiles does. Instead let it write both, then delete the instructions — the
# hook file's presence in ~/.copilot/hooks is the whole integration. --no-patch
# keeps settings.json / mcp-config.json chezmoi-managed. .chezmoiremove also
# lists the instructions file for idempotent cross-machine cleanup.
& rtk init -g --copilot --no-patch | Out-Null
Remove-Item -Force -ErrorAction SilentlyContinue "$env:USERPROFILE\.copilot\copilot-instructions.md"
{{ end -}}
