{{ if eq .chezmoi.os "windows" -}}
{{- $secrets := include "secrets.yaml.age" | decrypt | fromYaml -}}
# Set persistent user-level environment variables so GUI/desktop apps can access them.
# Rendered secret values are embedded below, so any rotation changes the file
# content and triggers chezmoi to re-run this script automatically.

# codex
[Environment]::SetEnvironmentVariable("CODEX_API_KEY", "{{ $secrets.codex_api_key }}", "User")

# mcps
[Environment]::SetEnvironmentVariable("CONTEXT7_API_KEY", "{{ $secrets.context7_api_key }}", "User")
[Environment]::SetEnvironmentVariable("GITHUB_PERSONAL_ACCESS_TOKEN", "{{ $secrets.github_personal_access_token }}", "User")
{{ end -}}
