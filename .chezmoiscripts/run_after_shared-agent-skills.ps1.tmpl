param(
    [string]$SuperpowersRoot = '{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/llm-agents/plugins/superpowers',
    [string]$MattpocockSkillsRoot = '{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/llm-agents/plugins/mattpocock-skills',
    [string]$SharedSkillsRoot = '{{ .chezmoi.homeDir | replace "\\" "/" }}/.agents/skills'
)

$ErrorActionPreference = 'Stop'

function Normalize-AbsolutePath([string]$Path, [string]$BasePath) {
    if (-not [IO.Path]::IsPathFullyQualified($Path)) { $Path = Join-Path $BasePath $Path }
    return [IO.Path]::TrimEndingDirectorySeparator([IO.Path]::GetFullPath($Path))
}

function Test-PathWithin([string]$Candidate, [string]$Root) {
    $prefix = $Root.TrimEnd('\', '/') + [IO.Path]::DirectorySeparatorChar
    return $Candidate.StartsWith($prefix, [StringComparison]::OrdinalIgnoreCase)
}

function Read-PluginManifest(
    [string]$Root,
    [string]$RelativePath,
    [string]$ExpectedName,
    [string]$Label
) {
    $manifestPath = Join-Path $Root $RelativePath
    $manifestItem = Get-Item -LiteralPath $manifestPath -Force -ErrorAction SilentlyContinue
    if ($null -eq $manifestItem -or $manifestItem.PSIsContainer) {
        throw "$Label manifest '$manifestPath' must exist and identify $ExpectedName."
    }
    try {
        $manifest = Get-Content -Raw -LiteralPath $manifestPath | ConvertFrom-Json
    }
    catch {
        throw "$Label manifest '$manifestPath' for $ExpectedName must be valid JSON: $($_.Exception.Message)"
    }
    $nameProperty = $manifest.PSObject.Properties['name']
    if ($null -eq $nameProperty -or [string]$nameProperty.Value -cne $ExpectedName) {
        throw "$Label manifest '$manifestPath' must name $ExpectedName."
    }
    return $manifest
}

function Get-SuperpowersSkillInventory([string]$Root) {
    $null = Read-PluginManifest $Root '.codex-plugin/plugin.json' 'superpowers' 'Superpowers'
    $null = Read-PluginManifest $Root '.claude-plugin/plugin.json' 'superpowers' 'Superpowers'
    $skillsRoot = Normalize-AbsolutePath (Join-Path $Root 'skills') $Root
    $skillsItem = Get-Item -LiteralPath $skillsRoot -Force -ErrorAction SilentlyContinue
    if ($null -eq $skillsItem -or -not $skillsItem.PSIsContainer) {
        throw "Superpowers skills directory '$skillsRoot' does not exist."
    }
    $inventory = @(
        Get-ChildItem -LiteralPath $skillsRoot -Directory -Force |
            Where-Object { Test-Path -LiteralPath (Join-Path $_.FullName 'SKILL.md') -PathType Leaf } |
            ForEach-Object {
                [pscustomobject]@{
                    Collection = 'superpowers'
                    Name = $_.Name
                    Target = Normalize-AbsolutePath $_.FullName $skillsRoot
                }
            } |
            Sort-Object Name
    )
    if ($inventory.Count -eq 0) {
        throw "Superpowers skills directory '$skillsRoot' contains no direct child skill with SKILL.md."
    }
    return $inventory
}

function Get-MattSkillInventory([string]$Root) {
    $manifest = Read-PluginManifest $Root '.claude-plugin/plugin.json' 'mattpocock-skills' 'Matt'
    $skillsProperty = $manifest.PSObject.Properties['skills']
    if (
        $null -eq $skillsProperty -or
        $skillsProperty.Value -isnot [Array] -or
        $skillsProperty.Value.Count -eq 0
    ) {
        throw 'Matt plugin manifest skills must be a non-empty array.'
    }

    $skillsRoot = Normalize-AbsolutePath (Join-Path $Root 'skills') $Root
    $inventory = @()
    foreach ($declaredPath in $skillsProperty.Value) {
        if ($declaredPath -isnot [string]) {
            throw 'Matt plugin manifest every skill path must be a string.'
        }
        $relativePath = $declaredPath
        if ($relativePath.StartsWith('./', [StringComparison]::Ordinal)) {
            $relativePath = $relativePath.Substring(2)
        }
        $components = @($relativePath -split '/')
        if (
            [IO.Path]::IsPathFullyQualified($relativePath) -or
            $relativePath.Contains('\') -or
            $components.Count -lt 2 -or
            $components[0] -cne 'skills' -or
            @($components | Where-Object { $_ -in @('', '.', '..') }).Count -ne 0
        ) {
            throw "Matt skill path '$declaredPath' must be a safe relative path beneath skills/."
        }

        $componentPath = $Root
        foreach ($component in $components) {
            $componentPath = Join-Path $componentPath $component
            $componentItem = Get-Item -LiteralPath $componentPath -Force -ErrorAction SilentlyContinue
            if (
                $null -ne $componentItem -and
                ($componentItem.Attributes -band [IO.FileAttributes]::ReparsePoint)
            ) {
                throw "Matt skill path '$declaredPath' traverses reparse point '$componentPath'."
            }
        }

        $target = Normalize-AbsolutePath (Join-Path $Root $relativePath) $Root
        if (-not (Test-PathWithin $target $skillsRoot)) {
            throw "Matt skill path '$declaredPath' escapes '$skillsRoot'."
        }
        $targetItem = Get-Item -LiteralPath $target -Force -ErrorAction SilentlyContinue
        if (
            $null -eq $targetItem -or
            -not $targetItem.PSIsContainer -or
            -not (Test-Path -LiteralPath (Join-Path $target 'SKILL.md') -PathType Leaf)
        ) {
            throw "Matt skill path '$declaredPath' must identify a directory containing SKILL.md."
        }
        $inventory += [pscustomobject]@{
            Collection = 'mattpocock-skills'
            Name = $targetItem.Name
            Target = $target
        }
    }
    return @($inventory | Sort-Object Name)
}

$basePath = (Get-Location).Path
$superpowersRootAbsolute = Normalize-AbsolutePath $SuperpowersRoot $basePath
$mattRootAbsolute = Normalize-AbsolutePath $MattpocockSkillsRoot $basePath
$sharedSkillsRootAbsolute = Normalize-AbsolutePath $SharedSkillsRoot $basePath
$ownedTargetRoots = @(
    Normalize-AbsolutePath (Join-Path $superpowersRootAbsolute 'skills') $basePath
    Normalize-AbsolutePath (Join-Path $mattRootAbsolute 'skills') $basePath
)

$desiredSkills = @(
    Get-SuperpowersSkillInventory $superpowersRootAbsolute
    Get-MattSkillInventory $mattRootAbsolute
)
$desiredByName = [Collections.Generic.Dictionary[string, object]]::new(
    [StringComparer]::OrdinalIgnoreCase
)
foreach ($desiredSkill in $desiredSkills) {
    if ($desiredByName.ContainsKey($desiredSkill.Name)) {
        $existing = $desiredByName[$desiredSkill.Name]
        throw "Shared skill duplicate name '$($desiredSkill.Name)' from '$($existing.Collection)' and '$($desiredSkill.Collection)'."
    }
    $desiredByName.Add($desiredSkill.Name, $desiredSkill)
}

$sharedSkillsItem = Get-Item -LiteralPath $sharedSkillsRootAbsolute -Force -ErrorAction SilentlyContinue
if ($null -ne $sharedSkillsItem -and -not $sharedSkillsItem.PSIsContainer) {
    throw "Shared skills root '$sharedSkillsRootAbsolute' is not a directory."
}
$existingEntries = if ($null -eq $sharedSkillsItem) {
    @()
} else {
    @(Get-ChildItem -LiteralPath $sharedSkillsRootAbsolute -Force)
}

$classifiedEntries = @()
foreach ($entry in $existingEntries) {
    $storedTargets = @(if ($null -eq $entry.LinkType) { @() } else { @($entry.LinkTarget) })
    $normalizedTargets = @()
    foreach ($storedTarget in $storedTargets) {
        if ($storedTarget -isnot [string] -or [string]::IsNullOrWhiteSpace($storedTarget)) {
            throw "Invalid stored LinkTarget for '$($entry.FullName)'."
        }
        try {
            $normalizedTargets += Normalize-AbsolutePath $storedTarget $sharedSkillsRootAbsolute
        }
        catch {
            throw "Invalid stored LinkTarget for '$($entry.FullName)': $($_.Exception.Message)"
        }
    }
    if ($null -ne $entry.LinkType -and $storedTargets.Count -eq 0) {
        throw "Invalid stored LinkTarget for '$($entry.FullName)': the link has no target."
    }

    $isWithinOwnedRoot = $false
    if ($normalizedTargets.Count -eq 1) {
        foreach ($ownedTargetRoot in $ownedTargetRoots) {
            if (Test-PathWithin $normalizedTargets[0] $ownedTargetRoot) {
                $isWithinOwnedRoot = $true
                break
            }
        }
    }
    $isOwned = (
        $entry.LinkType -eq 'SymbolicLink' -and
        $entry.PSIsContainer -and
        $storedTargets.Count -eq 1 -and
        [IO.Path]::IsPathFullyQualified([string]$storedTargets[0]) -and
        $normalizedTargets.Count -eq 1 -and
        $isWithinOwnedRoot
    )
    $classifiedEntries += [pscustomobject]@{ Item = $entry; IsOwned = $isOwned }
}

foreach ($classifiedEntry in $classifiedEntries) {
    if ($desiredByName.ContainsKey($classifiedEntry.Item.Name) -and -not $classifiedEntry.IsOwned) {
        throw "Refusing non-owned collision at '$($classifiedEntry.Item.FullName)'."
    }
}

if ($null -eq $sharedSkillsItem) {
    New-Item -ItemType Directory -Force -Path $sharedSkillsRootAbsolute | Out-Null
}
foreach ($classifiedEntry in $classifiedEntries) {
    if ($classifiedEntry.IsOwned) {
        Remove-Item -LiteralPath $classifiedEntry.Item.FullName -Force
    }
}
foreach ($desiredSkill in @($desiredByName.Values | Sort-Object Name)) {
    New-Item -ItemType SymbolicLink `
        -Path (Join-Path $sharedSkillsRootAbsolute $desiredSkill.Name) `
        -Target $desiredSkill.Target | Out-Null
}
