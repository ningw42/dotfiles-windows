{{- $colorscheme_choices := list "catppuccin-latte" "catppuccin-frappe" "catppuccin-macchiato" "catppuccin-mocha" "gruvbox-dark" -}}
{{- $colorscheme := promptChoiceOnce . "colorscheme" "colorscheme to use" $colorscheme_choices -}}

{{- $codex_provider_choices := list "litellm" "router-maestro" "copilot-proxy" "copilotd" -}}
{{- $claude_code_provider_choices := list "litellm" "router-maestro" "copilot-proxy" "copilotd" -}}
{{- $codex_provider := promptChoiceOnce . "codex_provider" "LLM provider for Codex" $codex_provider_choices -}}
{{- $claude_code_provider := promptChoiceOnce . "claude_code_provider" "LLM provider for Claude Code" $claude_code_provider_choices -}}

{{/* Derive the Anthropic base URL once here so settings.json.tmpl can stay a plain `{{ .claude_code_base_url }}` reference. */}}
{{- $claude_code_base_url := "" -}}
{{- if eq $claude_code_provider "litellm" -}}
{{-   $claude_code_base_url = "https://litellm.ningw.net" -}}
{{- else if eq $claude_code_provider "copilot-proxy" -}}
{{-   $claude_code_base_url = "https://copilot.ningw.net" -}}
{{- else if eq $claude_code_provider "copilotd" -}}
{{-   $claude_code_base_url = "https://copilotd.ningw.net/anthropic" -}}
{{- else -}}
{{-   $claude_code_base_url = "https://router-maestro.ningw.net/api/anthropic" -}}
{{- end -}}

{{- $password_manager_choices := list "1password" "bitwarden" -}}
{{- $password_manager := promptChoiceOnce . "password_manager" "password manager in use" $password_manager_choices -}}

{{- $git_username := promptStringOnce . "git_username" "git user name" -}}
{{- $git_useremail := promptStringOnce . "git_useremail" "git email address" -}}
{{- $git_signingkey := promptStringOnce . "git_signingkey" "git signing key" -}}

encryption = "age"

[age]
  identity = "~/.config/chezmoi/key.txt"
  recipient = "age1chwluerpyq4p9e340eeqatgm70939x769h7teh3tmr09f564hpyqdz2urt"

[data]
  colorscheme = {{ $colorscheme | quote }}
  password_manager = {{ $password_manager | quote }}
  git_username = {{ $git_username | quote }}
  git_useremail = {{ $git_useremail | quote }}
  codex_provider = {{ $codex_provider | quote }}
  claude_code_provider = {{ $claude_code_provider | quote }}
  claude_code_base_url = {{ $claude_code_base_url | quote }}
  git_signingkey = {{ $git_signingkey | quote }}

[diff]
  pager = "delta"
