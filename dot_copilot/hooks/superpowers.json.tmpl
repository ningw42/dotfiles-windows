{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "$env:COPILOT_CLI='1'; if (-not (Get-Command bash -CommandType Application -ErrorAction SilentlyContinue)) { $scoopRoot = if ($env:SCOOP) { $env:SCOOP } else { Join-Path $HOME 'scoop' }; $gitBin = Join-Path $scoopRoot 'apps/git/current/bin'; if (Test-Path -LiteralPath (Join-Path $gitBin 'bash.exe') -PathType Leaf) { $env:Path = $gitBin + [IO.Path]::PathSeparator + $env:Path } }; & '{{ .chezmoi.homeDir | replace "\\" "/" }}/.local/share/llm-agents/plugins/superpowers/hooks/run-hook.cmd' session-start",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
